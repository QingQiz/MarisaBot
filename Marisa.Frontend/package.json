{
  "name": "marisa.frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "npx vite serve --host 127.0.0.1",
    "build": "npx vite build"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "core-js": "^3.49.0",
    "d3": "^7.8.2",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@types/d3": "^7.4.0",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^9.1.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "~4.5.5",
    "vite": "^6.4.2"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/typescript"
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser"
    },
    "rules": {
      "no-unused-vars": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
